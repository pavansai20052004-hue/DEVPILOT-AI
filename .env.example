POSTGRES_DB=devpilot
POSTGRES_USER=devpilot
POSTGRES_PASSWORD=replace-with-a-long-random-password
SESSION_SECRET=replace-with-output-of-python-secrets-token-urlsafe-48

FRONTEND_ORIGINS=https://localhost
# Docker Compose routes /api through Nginx. Vercel and Netlify production should use the Render HTTPS backend URL.
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_ENABLE_LIVE_K8S_TWIN=false

LOG_LEVEL=INFO
AUTH_SESSION_TTL_SECONDS=2592000
AUTH_PASSWORD_RESET_TTL_SECONDS=1800
AUTH_EXPOSE_PASSWORD_RESET_TOKEN=false
HTTP_PORT=80
HTTPS_PORT=443

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_BASE_MODEL=gpt-5.4-mini
OPENAI_FINE_TUNED_MODEL=
DEVPILOT_CUSTOM_MODEL=
SLACK_WEBHOOK_URL=

GITHUB_TOKEN=
GITHUB_REPOSITORY=
GITHUB_BASE_BRANCH=main

DEVPILOT_MAX_REQUEST_BODY_BYTES=1500000
DEVPILOT_RATE_LIMIT_WINDOW_SECONDS=60
DEVPILOT_RATE_LIMIT_REQUESTS_PER_WINDOW=120

AUTONOMOUS_AGENT_ENABLED=true
AUTONOMOUS_AGENT_INTERVAL_SECONDS=15
AUTONOMOUS_AGENT_MODE=simulation
AUTONOMOUS_AGENT_APPLY_KUBERNETES=false
AUTONOMOUS_AGENT_REQUIRE_APPROVAL=true

# Production Kubernetes live mode:
# - Prefer KUBECONFIG_B64 on Render (base64-encoded kubeconfig YAML).
# - Use KUBECONFIG_CONTENT only when your host supports multiline secrets safely.
# - Use KUBECONFIG for local/dev file paths.
KUBECONFIG_B64=
KUBECONFIG_CONTENT=
KUBECONFIG=
