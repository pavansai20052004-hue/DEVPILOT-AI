APP_ENV=development
LOG_LEVEL=INFO

# Required in production. Use the Neon pooled PostgreSQL connection string.
DATABASE_URL=

# Required in production. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=dev-only-change-me-please-generate-a-real-secret
AUTH_SESSION_TTL_SECONDS=2592000
AUTH_PASSWORD_RESET_TTL_SECONDS=1800
# Keep false in production unless this is a controlled demo environment.
AUTH_EXPOSE_PASSWORD_RESET_TOKEN=false

# Optional: configure SMTP to send password reset links in production.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# Optional: enterprise SSO through any OIDC-compatible provider.
SSO_ENABLED=false
SSO_PROVIDER_ID=
SSO_PROVIDER_NAME=Company SSO
SSO_DISCOVERY_URL=
SSO_AUTHORIZATION_URL=
SSO_TOKEN_URL=
SSO_USERINFO_URL=
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_REDIRECT_URI=
SSO_ALLOWED_DOMAINS=
SSO_DEFAULT_TEAM_NAME=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_BASE_MODEL=gpt-5.4-mini
OPENAI_FINE_TUNED_MODEL=
DEVPILOT_CUSTOM_MODEL=
SLACK_WEBHOOK_URL=

# Local SQLite is allowed only outside production. Production requires DATABASE_URL.
INCIDENT_DB_PATH=
DEFAULT_USER_ROLE=viewer
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_ORIGIN_REGEX=
DEVPILOT_MAX_REQUEST_BODY_BYTES=1500000
DEVPILOT_RATE_LIMIT_WINDOW_SECONDS=60
DEVPILOT_RATE_LIMIT_REQUESTS_PER_WINDOW=120
KUBECONFIG_B64=
KUBECONFIG_CONTENT=
KUBECONFIG=
AUTONOMOUS_AGENT_ENABLED=true
AUTONOMOUS_AGENT_INTERVAL_SECONDS=15
AUTONOMOUS_AGENT_MODE=simulation
AUTONOMOUS_AGENT_APPLY_KUBERNETES=false
AUTONOMOUS_AGENT_REQUIRE_APPROVAL=true

# Required for /github/create-pull-request.
# Token scopes: public_repo for public repositories, repo for private repositories.
GITHUB_TOKEN=
GITHUB_REPOSITORY=owner/repo
GITHUB_BASE_BRANCH=main
